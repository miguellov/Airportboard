# Copia a .env para desarrollo local (npm start)
# En Render: añade estas variables en el dashboard del servicio

FA_API_KEY=tu_clave_flightaware_aeroapi
# En Render también vale API_KEY si ya la creaste con ese nombre
SYNC_SECRET=genera_un_secreto_largo_aleatorio
AIRPORT_CODE=MDPP
PORT=4000

# Primer usuario del panel (solo se crea si no hay usuarios en Firebase)
PANEL_BOOTSTRAP_USER=admin
PANEL_BOOTSTRAP_PASS=cambia_esta_clave
PANEL_JWT_SECRET=genera_un_secreto_largo_aleatorio
